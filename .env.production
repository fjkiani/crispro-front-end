# Production environment — committed intentionally (no secrets here).
# VITE_API_ROOT is a BUILD-TIME variable baked into the JS bundle by Vite.
# It must be in this file (or set as a Render build env var) so the deployed
# frontend calls the real backend instead of falling back to localhost:8000.
VITE_API_ROOT=https://crispro-backend-v2.onrender.com
# Enable mock auth bypass (no Supabase required). Login: ak@ak.com / any password.
VITE_ENABLE_MOCK_AUTH=true

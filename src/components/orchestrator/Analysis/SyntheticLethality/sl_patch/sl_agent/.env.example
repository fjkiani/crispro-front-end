# ─────────────────────────────────────────────────────────────────────────────
# SL Agent — environment configuration template
# Copy to .env and fill in values.  All fields are optional unless noted.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── DepMap ────────────────────────────────────────────────────────────────────
# Pin to a specific release (e.g. "24Q4") or leave as "latest" for auto-resolve
DEPMAP_RELEASE=latest

# Override Figshare download URLs if you mirror files internally.
# Use ndownloader.figshare.com (not figshare.com/ndownloader) — WAF blocks many script clients.
# DEPMAP_CRISPR_URL=https://ndownloader.figshare.com/files/51064667
# DEPMAP_MUTATION_URL=https://ndownloader.figshare.com/files/51065732
# DEPMAP_CNA_URL=https://ndownloader.figshare.com/files/51065324
# DEPMAP_EXPRESSION_URL=https://ndownloader.figshare.com/files/51065489
# DEPMAP_SAMPLE_INFO_URL=https://ndownloader.figshare.com/files/51065297
# DEPMAP_PRISM_URL=https://ndownloader.figshare.com/files/20237786
# DEPMAP_PRISM_META_URL=https://ndownloader.figshare.com/files/20237777

# Cache directories (default: .cache/<dataset>)
# DEPMAP_CACHE_DIR=.cache/depmap
# CHEMBL_CACHE_DIR=.cache/chembl
# GDSC_CACHE_DIR=.cache/gdsc

# ── Analysis thresholds ───────────────────────────────────────────────────────
FDR_THRESHOLD=0.25
DELTA_DEP_THRESHOLD=0.15
MIN_CELL_LINES_CANCER_SPECIFIC=30
DEPENDENCY_THRESHOLD=-0.5

# ── Open KB stack (CIViC + CGI + JAX) ────────────────────────────────────────
# No tokens required — all sources are CC0 / open access.
# Override CIViC nightly TSV URL if you want a pinned snapshot:
# CIVIC_NIGHTLY_TSV_URL=https://civicdb.org/downloads/nightly/nightly-ClinicalEvidenceSummaries.tsv

# ── DEPRECATED: OncoKB ────────────────────────────────────────────────────────
# OncoKB requires a commercial license and is no longer active in this stack.
# These env vars are parsed but ignored by all live code paths.
# ONCOKB_API_TOKEN=
# ONCOKB_BASE_URL=https://www.oncokb.org/api/v1

# ── GDSC (optional enrichment) ────────────────────────────────────────────────
# GDSC is available but NOT auto-loaded (150 MB Excel file).
# See orchestrator.py for wiring instructions.
# GDSC1_URL=https://cog.sanger.ac.uk/cancerrxgene/GDSC_release8.5/GDSC1_fitted_dose_response_27Oct23.xlsx
# GDSC2_URL=https://cog.sanger.ac.uk/cancerrxgene/GDSC_release8.5/GDSC2_fitted_dose_response_27Oct23.xlsx

# ── Cache TTL ─────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=86400

# ── Multi-Modal Evidence Engine (v4) ──────────────────────────────────────────
# No additional tokens required — all open sources.
# Frozen literature receipts (MBD4 cytidine-analog calibration) are built-in.
# To add GDSC pharmacologic enrichment, set gdsc_meta in orchestrator.py.
#
# POST /api/v1/analyze/multimodal   — full multi-modal matrix
# GET  /api/v1/analyze/calibration  — gold-standard calibration narrative
# GET  /api/v1/analyze/evidence_matrix?gene=MBD4  — frozen receipts only

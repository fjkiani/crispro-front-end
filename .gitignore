# ── Python — NEVER commit Python files into the frontend repo ──────────────────
# Backend code belongs in oncology-backend or oncology-backend-minimal.
*.py
*.py[cod]
*$py.class
__pycache__/
venv/
env/
ENV/
*.egg-info/
*.so
*.dylib
*.dll

